# App
APP_NAME=GridSense AI
APP_ENV=development
APP_PORT=8000

# Database
DATABASE_URL=postgresql://gridsense:gridsense123@localhost:5432/gridsense_db
TIMESCALE_URL=postgresql://gridsense:gridsense123@localhost:5432/gridsense_ts

# MQTT (Local broker for hackathon)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_TRANSFORMERS=gridsense/transformers/+/readings
MQTT_TOPIC_METERS=gridsense/meters/+/readings

# ML
MODEL_PATH=gridsense/ml/models/saved
ANOMALY_THRESHOLD=0.75
CRITICAL_THRESHOLD=0.90
PREDICTION_WINDOW_HOURS=72

# GenAI
GEMMA_MODEL_PATH=models/gemma4
LLM_PROVIDER=local
LOCAL_LLM_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=gemma4
LOCAL_MODEL_PATH=E:\llm\models\gemma4-e4b\google_gemma-4-E4B-it-Q4_K_M.gguf
LLAMA_SERVER_PATH=E:\llm\bin\llama-server.exe
CTX_SIZE=4096

# Simulation
NUM_TRANSFORMERS=100
METERS_PER_TRANSFORMER=50
SIMULATION_INTERVAL_SECONDS=5
DEGRADING_TRANSFORMERS=T-047,T-023,T-081
THEFT_METERS=M-04702,M-02341,M-08115
